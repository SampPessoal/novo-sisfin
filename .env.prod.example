# ========================================
# SisFin - Variáveis de Produção
# ========================================
# Opção 1: VPS com Docker -> copie para .env.prod
# Opção 2: Supabase + Render -> configure nas plataformas

# Banco de dados
# Local: postgresql://postgres:SenhaForte@postgres:5432/sisfin?schema=public
# Supabase: copie de Project Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://postgres:SenhaForte@localhost:5432/sisfin?schema=public"
DB_PASSWORD="SenhaForte"

# JWT (gere com: openssl rand -hex 32)
JWT_SECRET=""
JWT_REFRESH_SECRET=""

# Redis
# Local: deixe vazio
# Upstash: copie de Console > Redis > REST URL
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# URL pública do frontend (sem / no final)
FRONTEND_URL="https://seu-usuario.github.io/sisfin"

# Porta (apenas para Docker)
APP_PORT=80

# Storage
STORAGE_PROVIDER="local"

# Email (opcional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="financeiro@empresa.com.br"

# OpenAI (opcional)
OPENAI_API_KEY=""
