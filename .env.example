# ===== Banco de Dados (PostgreSQL / Supabase) =====
DATABASE_URL="postgresql://postgres:SuaSenha@localhost:5432/sisfin?schema=public"

# ===== JWT =====
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_64_CHARS"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_SECRET_64_CHARS"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ===== Redis (Upstash para produção) =====
REDIS_HOST="localhost"
REDIS_PORT=6379

# ===== Storage (S3 ou Azure Blob) =====
STORAGE_PROVIDER="local"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="sa-east-1"
AWS_S3_BUCKET="sisfin-comprovantes"

# ===== Asaas =====
ASAAS_API_KEY=""
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
ASAAS_WEBHOOK_TOKEN=""

# ===== PlugNotas =====
PLUGNOTAS_API_KEY=""
PLUGNOTAS_BASE_URL="https://api.plugnotas.com.br"

# ===== WhatsApp Business API =====
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_WEBHOOK_SECRET=""

# ===== OCR =====
OCR_PROVIDER="extractlab"
EXTRACTLAB_API_KEY=""

# ===== Email =====
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="financeiro@empresa.com.br"

# ===== OpenAI =====
OPENAI_API_KEY=""

# ===== Aplicacao =====
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
